# ==========================================
# Monospace Studio — NASA APOD ASCII Art Studio
# Environment Configuration Template
# ==========================================

# ------------------------------------------
# 1. NASA API Credentials
# Register for a free API key at https://api.nasa.gov
# ------------------------------------------
NASA_API_KEY=your_nasa_api_key_here

# ------------------------------------------
# 2. Supabase Connection Details
# Get these from your Supabase Project Settings -> API
# ------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ------------------------------------------
# 3. LLM Configuration
# Set LLM_PROVIDER to one of: trussed | openai-compatible | openai
# And fill out the corresponding provider block below.
# ------------------------------------------
LLM_PROVIDER=openai-compatible

# --- Option A: LM Studio (Local Dev Default) ---
# OPENAI_API_KEY can be any non-empty string.
# Ensure an instruct model is running on the specified port.
OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://localhost:1234/v1
LLM_MODEL=qwen/qwen2.5-27b-instruct

# --- Option B: FAU Trussed (Demo & Production Default) ---
# TRUSSED_API_KEY is your FAU course-assigned key.
# TRUSSED_BASE_URL=https://fauengtrussed.fau.edu/provider/generic
# LLM_MODEL=cogito:14b
# TRUSSED_API_KEY=your_fau_assigned_key
# TRUSSED_BASE_URL=https://fauengtrussed.fau.edu/provider/generic
# LLM_MODEL=cogito:14b

# --- Option C: Ollama (Local Alternative) ---
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b-instruct

# --- Option D: Direct OpenAI (Paid Tier) ---
# OPENAI_API_KEY=sk-proj-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
